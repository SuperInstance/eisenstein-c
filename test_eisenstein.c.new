/*
 * test_eisenstein.c — Tests for the new Eisenstein integer library functions.
 *
 * Compile alongside eisenstein.c (e.g.):
 *   cc -std=c11 -Wall -Wextra -o test_eisenstein \
 *       test_eisenstein.c eisenstein.c -lm && ./test_eisenstein
 *
 * All tests use assert(); a passing run prints "All tests passed." and exits 0.
 */

#include "eisenstein.h"
#include <assert.h>
#include <stdio.h>
#include <string.h>

/* ── Helpers ──────────────────────────────────────────────────────────────── */

static e12_t mk(int32_t a, int32_t b) {
    e12_t z = { a, b };
    return z;
}

/* Count how many times z appears in the array pts[0..n). */
static int count_occurrences(e12_t z, const e12_t *pts, size_t n) {
    int c = 0;
    for (size_t i = 0; i < n; i++) {
        if (e12_eq(pts[i], z)) c++;
    }
    return c;
}

/* ── e12_div ──────────────────────────────────────────────────────────────── */

static void test_div(void) {
    /* Property: x = q*y + r  AND  N(r) < N(y) for all test cases. */
    struct { e12_t x; e12_t y; } cases[] = {
        { mk(7,  0), mk(2,  1) },   /* 7 / (2+ω) */
        { mk(5,  3), mk(1,  1) },   /* divide by a unit — quotient = x */
        { mk(13, 0), mk(3,  1) },
        { mk(0,  0), mk(1,  0) },   /* zero numerator */
        { mk(1,  0), mk(0,  1) },   /* divide 1 by ω */
        { mk(10, 5), mk(3, -1) },
        { mk(-7, 4), mk(2,  3) },
        { mk(100, 50), mk(7,  3) },
    };

    for (size_t i = 0; i < sizeof(cases)/sizeof(cases[0]); i++) {
        e12_t x = cases[i].x;
        e12_t y = cases[i].y;
        e12_t rem;
        e12_t q = e12_div(x, y, &rem);

        /* x == q*y + r */
        e12_t reconstructed = e12_add(e12_mul(q, y), rem);
        assert(e12_eq(reconstructed, x) && "e12_div: x != q*y + r");

        /* N(r) < N(y) */
        int64_t nr = e12_norm(rem);
        int64_t ny = e12_norm(y);
        assert(nr < ny && "e12_div: N(rem) >= N(y)");
    }

    /* NULL rem pointer should not crash */
    e12_t q = e12_div(mk(13, 0), mk(3, 1), NULL);
    e12_t r;
    e12_div(mk(13, 0), mk(3, 1), &r);
    assert(e12_eq(e12_add(e12_mul(q, mk(3,1)), r), mk(13,0)));

    puts("e12_div: OK");
}

/* ── e12_gcd ──────────────────────────────────────────────────────────────── */

static void test_gcd(void) {
    /* Property: gcd(x,y) divides both x and y.
     * We verify by checking that the remainder is zero. */
    struct { e12_t x; e12_t y; } cases[] = {
        { mk(6,  0), mk(4,  0) },   /* gcd = 2 */
        { mk(7,  0), mk(3,  1) },   /* 7 = (3+ω)(a,b)... */
        { mk(0,  0), mk(5,  2) },   /* gcd(0, y) = y */
        { mk(5,  2), mk(0,  0) },   /* gcd(x, 0) = x */
        { mk(1,  0), mk(7,  3) },   /* gcd with unit → unit */
        { mk(12, 0), mk(8,  0) },
        { mk(7,  7), mk(7,  0) },
    };

    for (size_t i = 0; i < sizeof(cases)/sizeof(cases[0]); i++) {
        e12_t x = cases[i].x;
        e12_t y = cases[i].y;
        e12_t g = e12_gcd(x, y);

        /* g must divide x */
        if (!e12_eq(g, E12_ZERO)) {
            e12_t rem;
            e12_div(x, g, &rem);
            assert(e12_eq(rem, E12_ZERO) && "e12_gcd: g does not divide x");

            /* g must divide y */
            e12_div(y, g, &rem);
            assert(e12_eq(rem, E12_ZERO) && "e12_gcd: g does not divide y");
        } else {
            /* gcd is zero only when both inputs are zero */
            assert(e12_eq(x, E12_ZERO) && e12_eq(y, E12_ZERO));
        }
    }

    /* gcd(0, 0) == 0 */
    assert(e12_eq(e12_gcd(E12_ZERO, E12_ZERO), E12_ZERO));

    /* gcd is commutative up to units (norms must match) */
    e12_t g1 = e12_gcd(mk(6, 0), mk(4, 0));
    e12_t g2 = e12_gcd(mk(4, 0), mk(6, 0));
    assert(e12_norm(g1) == e12_norm(g2) && "e12_gcd: not commutative up to norm");

    puts("e12_gcd: OK");
}

/* ── e12_is_prime ─────────────────────────────────────────────────────────── */

static void test_is_prime(void) {
    /* Units — not prime */
    assert(!e12_is_prime(mk( 1,  0)));
    assert(!e12_is_prime(mk(-1,  0)));
    assert(!e12_is_prime(mk( 0,  1)));
    assert(!e12_is_prime(mk( 0, -1)));
    assert(!e12_is_prime(mk( 1,  1)));
    assert(!e12_is_prime(mk(-1, -1)));

    /* Zero — not prime */
    assert(!e12_is_prime(E12_ZERO));

    /* ── Ramified prime above 3: associates of 1−ω ── */
    /* 1−ω = (1, -1), N = 3 */
    assert(e12_is_prime(mk( 1, -1)));
    /* −(1−ω) = (−1, 1) */
    assert(e12_is_prime(mk(-1,  1)));
    /* ω·(1−ω) = (1−ω rotated): e12_rotate_60((1,-1)) = (1, 1+1) = (1, 2) */
    assert(e12_is_prime(mk( 2,  1)));  /* N = 4-2+1 = 3 */
    assert(e12_is_prime(mk(-2, -1)));
    assert(e12_is_prime(mk( 1,  2)));  /* N = 1-2+4 = 3 */
    assert(e12_is_prime(mk(-1, -2)));

    /* ── Split prime: p ≡ 1 mod 3, norm = p ── */
    /* 7 ≡ 1 mod 3. Factors: (3+ω) and (2-ω) — let's verify. */
    /* (3,1): N = 9-3+1 = 7 ✓ */
    assert(e12_is_prime(mk(3,  1)));
    assert(e12_is_prime(mk(2, -1)));   /* N = 4+2+1 = 7 ✓  Wait: 4-(-2)+1=7 ✓ */
    /* 13 ≡ 1 mod 3. (4,1): N = 16-4+1=13. */
    assert(e12_is_prime(mk(4,  1)));
    assert(e12_is_prime(mk(3, -1)));   /* N = 9+3+1 = 13 ✓ */
    /* 19 ≡ 1 mod 3. (5,1)? N=25-5+1=21 ✗. Try (4,3): N=16-12+9=13 ✗. */
    /* (5,2)? N=25-10+4=19 ✓ */
    assert(e12_is_prime(mk(5,  2)));
    assert(e12_is_prime(mk(3, -2)));   /* N=9+6+4=19 ✓ */

    /* ── Inert prime: p ≡ 2 mod 3, norm = p² ── */
    /* 2 ≡ 2 mod 3.  z = (2,0): N = 4 = 2². */
    assert(e12_is_prime(mk( 2,  0)));
    assert(e12_is_prime(mk(-2,  0)));
    /* 5 ≡ 2 mod 3.  z = (5,0): N = 25 = 5². */
    assert(e12_is_prime(mk( 5,  0)));
    assert(e12_is_prime(mk(-5,  0)));
    /* 11 ≡ 2 mod 3. z = (11,0): N = 121 = 11². */
    assert(e12_is_prime(mk(11,  0)));

    /* ── Composite Eisenstein integers — not prime ── */
    /* (2+ω)(2+ω) = ? */
    e12_t z = e12_mul(mk(2, 1), mk(2, 1));  /* N = 7*7 = 49 */
    assert(!e12_is_prime(z));
    /* 6 = 2·3, N(6,0) = 36 */
    assert(!e12_is_prime(mk(6, 0)));
    /* 4 = 2², N(4,0) = 16 */
    assert(!e12_is_prime(mk(4, 0)));
    /* norm 49 = 7²; 7≡1 mod 3, so this is NOT an inert prime squared */
    assert(!e12_is_prime(mk(7, 0)));

    puts("e12_is_prime: OK");
}

/* ── e12_from_norm ────────────────────────────────────────────────────────── */

static void test_from_norm(void) {
    size_t cnt;
    e12_t *pts;

    /* norm 0 → only (0,0) */
    pts = e12_from_norm(0, &cnt);
    assert(cnt == 1 && pts != NULL);
    assert(e12_eq(pts[0], E12_ZERO));
    free(pts);

    /* norm 1 → exactly the 6 units */
    pts = e12_from_norm(1, &cnt);
    assert(cnt == 6 && pts != NULL);
    /* Verify every result truly has norm 1 */
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 1);
    /* Spot-check known units */
    assert(count_occurrences(mk( 1,  0), pts, cnt) == 1);
    assert(count_occurrences(mk(-1,  0), pts, cnt) == 1);
    assert(count_occurrences(mk( 0,  1), pts, cnt) == 1);
    assert(count_occurrences(mk( 0, -1), pts, cnt) == 1);
    assert(count_occurrences(mk( 1,  1), pts, cnt) == 1);
    assert(count_occurrences(mk(-1, -1), pts, cnt) == 1);
    free(pts);

    /* norm 3 → 6 associates of 1−ω */
    pts = e12_from_norm(3, &cnt);
    assert(cnt == 6 && pts != NULL);
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 3);
    assert(count_occurrences(mk( 1, -1), pts, cnt) == 1);
    assert(count_occurrences(mk(-1,  1), pts, cnt) == 1);
    assert(count_occurrences(mk( 2,  1), pts, cnt) == 1);
    assert(count_occurrences(mk(-2, -1), pts, cnt) == 1);
    assert(count_occurrences(mk( 1,  2), pts, cnt) == 1);
    assert(count_occurrences(mk(-1, -2), pts, cnt) == 1);
    free(pts);

    /* norm 4 = 2²; 2 is inert (2≡2 mod 3), so 12 solutions (6 units × 2 associates) */
    pts = e12_from_norm(4, &cnt);
    assert(cnt == 6 && pts != NULL);   /* 2 is associate to itself up to units only */
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 4);
    free(pts);

    /* norm 7; 7≡1 mod 3, splits, so 12 solutions */
    pts = e12_from_norm(7, &cnt);
    assert(cnt == 12 && pts != NULL);
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 7);
    /* Spot-check a few */
    assert(count_occurrences(mk(3,  1), pts, cnt) == 1);
    assert(count_occurrences(mk(1,  3), pts, cnt) == 1);
    assert(count_occurrences(mk(2, -1), pts, cnt) == 1);
    free(pts);

    /* norm 13; 13≡1 mod 3, splits, so 12 solutions */
    pts = e12_from_norm(13, &cnt);
    assert(cnt == 12 && pts != NULL);
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 13);
    free(pts);

    /* negative norm → NULL */
    pts = e12_from_norm(-1, &cnt);
    assert(pts == NULL && cnt == 0);

    /* norm 2 (2≡2 mod 3, inert → no Eisenstein factorisation at this norm) */
    pts = e12_from_norm(2, &cnt);
    assert(cnt == 0 && pts == NULL);

    /* Verify all returned points actually have the claimed norm (random norm) */
    pts = e12_from_norm(19, &cnt);
    for (size_t i = 0; i < cnt; i++)
        assert(e12_norm(pts[i]) == 19);
    free(pts);

    puts("e12_from_norm: OK");
}

/* ── e12_hash ─────────────────────────────────────────────────────────────── */

static void test_hash(void) {
    /* Equal elements → same hash */
    assert(e12_hash(mk(3, 7)) == e12_hash(mk(3, 7)));
    assert(e12_hash(E12_ZERO)  == e12_hash(E12_ZERO));
    assert(e12_hash(E12_ONE)   == e12_hash(E12_ONE));
    assert(e12_hash(E12_OMEGA) == e12_hash(E12_OMEGA));

    /* Different elements should (with overwhelming probability) differ */
    assert(e12_hash(mk(1, 0)) != e12_hash(mk(0, 1)));
    assert(e12_hash(mk(1, 0)) != e12_hash(mk(0, 0)));
    assert(e12_hash(mk(3, 7)) != e12_hash(mk(7, 3)));
    assert(e12_hash(mk(1000, -500)) != e12_hash(mk(-500, 1000)));

    /* Smoke-test: no collision in a small neighbourhood */
    {
        uint64_t hashes[25];
        int k = 0;
        for (int a = -2; a <= 2; a++)
            for (int b = -2; b <= 2; b++)
                hashes[k++] = e12_hash(mk(a, b));
        /* Check all 25 are distinct (no collision in this tiny grid) */
        for (int i = 0; i < 25; i++)
            for (int j = i + 1; j < 25; j++)
                assert(hashes[i] != hashes[j] && "e12_hash: collision in 5×5 grid");
    }

    puts("e12_hash: OK");
}

/* ── Cross-function integration tests ───────────────────────────────────── */

static void test_integration(void) {
    /*
     * from_norm should return exactly the elements reported prime by is_prime
     * when the norm is a rational prime p ≡ 1 mod 3.
     */
    int64_t split_primes[] = { 7, 13, 19, 31, 37 };
    for (size_t pi = 0; pi < 5; pi++) {
        int64_t p = split_primes[pi];
        size_t cnt;
        e12_t *pts = e12_from_norm(p, &cnt);
        assert(cnt == 12);
        for (size_t i = 0; i < cnt; i++)
            assert(e12_is_prime(pts[i]) &&
                   "split prime associate should be Eisenstein prime");
        free(pts);
    }

    /*
     * gcd(x, x) should have the same norm as x for non-zero x.
     */
    e12_t samples[] = { mk(3,1), mk(5,2), mk(2,0), mk(7,0) };
    for (size_t i = 0; i < 4; i++) {
        e12_t g = e12_gcd(samples[i], samples[i]);
        assert(e12_norm(g) == e12_norm(samples[i]) &&
               "gcd(x,x) norm != norm(x)");
    }

    /*
     * div then gcd consistency: gcd(y, x mod y) should have the same norm
     * as gcd(x, y).
     */
    {
        e12_t x = mk(12, 4), y = mk(4, 1);
        e12_t rem;
        e12_div(x, y, &rem);
        e12_t g1 = e12_gcd(x, y);
        e12_t g2 = e12_gcd(y, rem);
        assert(e12_norm(g1) == e12_norm(g2));
    }

    puts("integration: OK");
}

/* ── main ─────────────────────────────────────────────────────────────────── */

int main(void) {
    test_div();
    test_gcd();
    test_is_prime();
    test_from_norm();
    test_hash();
    test_integration();

    puts("\nAll tests passed.");
    return 0;
}
